# Sri Ram Fashions Backend Environment Variables

# Required: MongoDB Connection
MONGODB_URI=mongodb+srv://your_username:your_password@cluster0.xxxxx.mongodb.net/sri-ram-fashions

# Required: JWT signing key
JWT_SECRET=replace_with_a_long_random_secret

# Optional: Frontend URL (for CORS allow-list)
FRONTEND_URL=http://localhost:5173

# Optional: Server port
PORT=5000

# Optional: Email delivery
# Preferred for production
RESEND_API_KEY=
RESEND_FROM=
# Gmail SMTP fallback
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
# Default recipients for manual reports, alerts, and scheduler jobs
ADMIN_EMAIL=

# Optional: Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
# Optional: comma-separated list if multiple frontend origins use different Google client IDs
# GOOGLE_CLIENT_IDS=web_client_id_1,web_client_id_2

# Optional: Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: bootstrap an admin user on server startup
# Set BOOTSTRAP_DEFAULT_ADMIN=true only for controlled setups.
BOOTSTRAP_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_NAME=Admin User
DEFAULT_ADMIN_PHONE=

# Optional: seed-script admin credentials (npm run seed)
SEED_ADMIN_EMAIL=admin@sriramfashions.com
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin User
SEED_ADMIN_PHONE=9876543210
