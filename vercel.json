{
  "version": 2,
  "buildCommand": "cd frontend-new && npm install && npm run build",
  "outputDirectory": "frontend-new/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/src/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "backend/src/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
