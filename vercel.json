{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "frontend-new/dist",
  "installCommand": "npm install --prefix frontend-new && npm install --prefix backend",
  "rewrites": [
    {
      "source": "/api/v1/:path*",
      "destination": "/api"
    },
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend-new/dist/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
