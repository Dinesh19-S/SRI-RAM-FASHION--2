# Sri Ram Fashions Frontend Environment Variables

# Backend API base URL
VITE_API_URL=http://localhost:5000/api/v1
# Optional: use current site origin as API host in production
# VITE_API_USE_ORIGIN=true

# Google OAuth client ID for login
# Must be a Google OAuth "Web application" client ID.
# Add your running origin (e.g. http://localhost:5173) in Google Cloud Console
# -> APIs & Services -> Credentials -> Authorized JavaScript origins.
VITE_GOOGLE_CLIENT_ID=
